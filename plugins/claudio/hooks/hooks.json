{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/inject_rules.py\"",
            "statusMessage": "Loading claudio coding rules..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/quality_gate.py\"",
            "timeout": 600,
            "statusMessage": "Running claudio quality gate..."
          }
        ]
      }
    ]
  }
}
